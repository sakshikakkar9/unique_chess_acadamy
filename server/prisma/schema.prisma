generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Event {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  location    String?
  category    EventCategory
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Tournament {
  id              Int               @id @default(autoincrement())
  title           String
  description     String?           @db.Text
  startDate       DateTime          // Updated from 'date'
  endDate         DateTime?         // New
  location        String?
  category        String?           // New: Text box requirement
  totalPrizePool  String?           // New
  entryFee        Float             @default(0.0)
  discountDetails String?           // New: The "text box right below entry fee"
  brochureUrl     String?           // New: For the brochure upload
  otherDetails    String?           @db.Text // New
  contactDetails  String?           // New
  status          TournamentStatus  @default(UPCOMING)
  imageUrl        String?           
  
  results         TournamentResult[] 
  registrations   Registration[]     
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model TournamentResult {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  position     Int
  playerName   String
  score        Float?
  prize        String?
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        String          @id @default(uuid())
  imageUrl  String
  caption   String?
  category  GalleryCategory @default(ACADEMY)
  createdAt DateTime        @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model Registration {
  id              String     @id @default(uuid())
  referenceId     String     @unique @default(cuid()) // ✅ NEW: Unique Reference for the user
  studentName     String
  gender          String     // ✅ NEW: Male, Female, Other
  category        String?    // ✅ NEW: Tournament category selected by player
  dob             DateTime   // ✅ NEW: Date of Birth
  email           String?    // ✅ Mandatory check handled in frontend logic
  phone           String
  
  // FIDE Details
  fideId          String     @default("NA") // ✅ NEW: Default set to NA
  fideRating      Int        @default(0)    // ✅ NEW: Default set to 0
  
  address         String     @db.Text       // ✅ NEW
  
  // Proofs (Storage URLs)
  ageProofUrl     String     // ✅ NEW: Document upload link
  paymentProofUrl String     // ✅ NEW: Screenshot of payment link
  
  // Discovery
  discoverySource String     // ✅ NEW: Social media, WhatsApp, etc.
  
  transactionId   String?
  tournamentId    Int
  status          String     @default("PENDING")
  createdAt       DateTime   @default(now())
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model DemoRegistration {
  id          Int      @id @default(autoincrement())
  studentName String
  email       String
  phone       String
  scheduledAt DateTime
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Course {
  id          Int                @id @default(autoincrement())
  title       String
  ageGroup    AgeGroup           @default(ADULTS)
  minAge      Int?
  maxAge      Int?
  level       String             @default("Beginner")
  duration    String             @default("Flexible")
  description String?
  image       String?
  price       String?
  features    String[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  enrollments CourseEnrollment[]
}

model CourseEnrollment {
  id          Int      @id @default(autoincrement())
  studentName String
  email       String
  phone       String
  mode        String   @default("OFFLINE")
  courseId    Int
  message     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventCategory {
  CLASS
  WORKSHOP
}

enum GalleryCategory {
  TRAINING
  TOURNAMENT
  COACHING
  ACADEMY
}

enum AgeGroup {
  CHILDREN
  TEENAGERS
  ADULTS
}
