generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GlobalSettings {
  id            String   @id @default("default")
  upiScannerUrl String?
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  phone     String   @default("")
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model Tournament {
  id                Int                @id @default(autoincrement())
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime?
  location          String?
  category          String?
  totalPrizePool    String?
  entryFee          Float              @default(0.0)
  discountDetails   String?
  brochureUrl       String?
  otherDetails      String?
  contactDetails    String?
  regStartDate      DateTime?
  regEndDate        DateTime?
  posterOrientation PosterOrientation  @default(LANDSCAPE)
  status            String?
  imageUrl          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  registrations     Registration[]
  results           TournamentResult[]
}

model TournamentResult {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  position     Int
  playerName   String
  score        Float?
  prize        String?
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        String          @id @default(uuid())
  imageUrl  String
  caption   String?
  category  GalleryCategory @default(ACADEMY)
  createdAt DateTime        @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model Student {
  id              String             @id @default(uuid())
  fullName        String
  email           String?
  phone           String             @unique
  gender          String
  dob             DateTime
  address         String
  fideId          String?            @default("NA")
  fideRating      Int?               @default(0)
  clubAffiliation String?
  experienceLevel String?
  preferredBatch  String?
  discoverySource String?
  accountStatus   String             @default("ACTIVE")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  enrollments     CourseEnrollment[]
  registrations   Registration[]
}

model Registration {
  id              String        @id @default(uuid())
  referenceId     String        @unique @default(cuid())
  studentId       String
  email           String?
  fideId          String?
  fideRating      Int?
  discoverySource String?
  category        String?
  ageProofUrl     String
  paymentProofUrl String
  transactionId   String?
  tournamentId    Int
  status          String        @default("PENDING")
  paymentStatus   PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tournament      Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model DemoRegistration {
  id          Int      @id @default(autoincrement())
  studentName String
  email       String
  phone       String
  scheduledAt DateTime
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Course {
  id                String             @id @default(cuid())
  title             String
  description       String?
  ageGroup          String
  skillLevel        SkillLevel         @default(BEGINNER)
  classTime         String
  duration          String
  fee               Float
  days              String[]
  contactDetails    String
  mode              ClassMode          @default(ONLINE)
  startDate         DateTime?
  endDate           DateTime?
  status            String?
  custom_banner_url String?
  brochureUrl       String?
  posterOrientation PosterOrientation  @default(LANDSCAPE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  enrollments       CourseEnrollment[]

  @@map("courses")
}

model CourseEnrollment {
  id              String        @id @default(uuid())
  referenceId     String        @unique @default(cuid())
  studentId       String
  discoverySource String?
  category        String?
  ageProofUrl     String
  paymentProofUrl String
  transactionId   String?
  status          String        @default("PENDING")
  paymentStatus   PaymentStatus @default(PENDING)
  courseId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  GRANDMASTER
}

enum ClassMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum PaymentStatus {
  PENDING
  VERIFIED
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum PosterOrientation {
  LANDSCAPE
  PORTRAIT
}

enum GalleryCategory {
  TRAINING
  TOURNAMENT
  COACHING
  ACADEMY
}

enum AgeGroup {
  CHILDREN
  TEENAGERS
  ADULTS
}
