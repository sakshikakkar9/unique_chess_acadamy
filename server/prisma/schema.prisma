generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  GRANDMASTER
}

enum ClassMode {
  ONLINE
  OFFLINE
  HYBRID
}

model Event {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  location    String?
  category    EventCategory
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Tournament {
  id              Int               @id @default(autoincrement())
  title           String
  description     String?           @db.Text
  startDate       DateTime          // Updated from 'date'
  endDate         DateTime?         // New
  location        String?
  category        String?           // New: Text box requirement
  totalPrizePool  String?           // New
  entryFee        Float             @default(0.0)
  discountDetails String?           // New: The "text box right below entry fee"
  brochureUrl     String?           // New: For the brochure upload
  otherDetails    String?           @db.Text // New
  contactDetails  String?           // New
  status          TournamentStatus  @default(UPCOMING)
  imageUrl        String?           
  scannerUrl      String?
  
  results         TournamentResult[] 
  registrations   Registration[]     
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model TournamentResult {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  position     Int
  playerName   String
  score        Float?
  prize        String?
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        String          @id @default(uuid())
  imageUrl  String
  caption   String?
  category  GalleryCategory @default(ACADEMY)
  createdAt DateTime        @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model Registration {
  id              String     @id @default(uuid())
  referenceId     String     @unique @default(cuid()) // ✅ NEW: Unique Reference for the user
  studentName     String
  gender          String     // ✅ NEW: Male, Female, Other
  category        String?    // ✅ NEW: Tournament category selected by player
  dob             DateTime   // ✅ NEW: Date of Birth
  email           String?    // ✅ Mandatory check handled in frontend logic
  phone           String
  
  // FIDE Details
  fideId          String     @default("NA") // ✅ NEW: Default set to NA
  fideRating      Int        @default(0)    // ✅ NEW: Default set to 0
  
  address         String     @db.Text       // ✅ NEW
  
  // Proofs (Storage URLs)
  ageProofUrl     String     // ✅ NEW: Document upload link
  paymentProofUrl String     // ✅ NEW: Screenshot of payment link
  
  // Discovery
  discoverySource String     // ✅ NEW: Social media, WhatsApp, etc.
  
  transactionId   String?
  tournamentId    Int
  status          String     @default("PENDING")
  createdAt       DateTime   @default(now())
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model DemoRegistration {
  id          Int      @id @default(autoincrement())
  studentName String
  email       String
  phone       String
  scheduledAt DateTime
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Course {
  id             String             @id @default(cuid())
  title          String
  ageGroup       String             // e.g., "Kids (5-10)", "Adults"
  skillLevel     SkillLevel         @default(BEGINNER)
  classTime      String             // e.g., "17:00"
  duration       String             // e.g., "60 mins"
  fee            Float
  days           String[]           // e.g., ["Monday", "Wednesday"]
  contactDetails String
  mode           ClassMode          @default(ONLINE)
  custom_banner_url String?            // URL from storage bucket
  scannerUrl     String?            // New: QR Payment image
  
  enrollments    CourseEnrollment[] 

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("courses")
}

model CourseEnrollment {
  id              String   @id @default(uuid())
  referenceId     String   @unique @default(cuid())
  studentName     String
  gender          String   // Male, Female, Other
  category        String?  
  dob             DateTime
  email           String?  // Not mandatory
  phone           String
  
  // FIDE Details
  fideId          String   @default("NA")
  fideRating      Int      @default(0)
  
  address         String   @db.Text
  
  // Proofs (Storage URLs)
  ageProofUrl      String   
  paymentProofUrl  String   
  
  // Discovery
  discoverySource  String   
  
  transactionId   String?
  experienceLevel String?

  status          String   @default("PENDING")
  courseId        String   
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventCategory {
  CLASS
  WORKSHOP
}

enum GalleryCategory {
  TRAINING
  TOURNAMENT
  COACHING
  ACADEMY
}

enum AgeGroup {
  CHILDREN
  TEENAGERS
  ADULTS
}
